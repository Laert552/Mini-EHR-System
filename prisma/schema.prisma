// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────
// Enums
// ─────────────────────────────────────────────

enum Role {
  ADMIN
  DOCTOR
  PATIENT
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  CANCELLED
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

// ─────────────────────────────────────────────
// User (auth identity + role)
// ─────────────────────────────────────────────

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  role      Role
  createdAt DateTime @default(now())

  doctorProfile  DoctorProfile?
  patientProfile PatientProfile?
}

// ─────────────────────────────────────────────
// Doctor Profile
// ─────────────────────────────────────────────

model DoctorProfile {
  id         String @id @default(uuid())
  userId     String @unique
  specialty  String
  experience Int

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  appointments Appointment[]
}

// ─────────────────────────────────────────────
// Patient Profile
// ─────────────────────────────────────────────

model PatientProfile {
  id        String   @id @default(uuid())
  userId    String   @unique
  fullName  String
  birthDate DateTime
  gender    Gender

  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  appointments   Appointment[]
  medicalRecords MedicalRecord[]
  labResults     LabResult[]
}

// ─────────────────────────────────────────────
// Appointment
// ─────────────────────────────────────────────

model Appointment {
  id        String            @id @default(uuid())
  doctorId  String
  patientId String
  date      DateTime
  status    AppointmentStatus @default(PENDING)
  createdAt DateTime          @default(now())

  doctor  DoctorProfile  @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  patient PatientProfile @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([doctorId, date])
}

// ─────────────────────────────────────────────
// Medical Record (EMR)
// ─────────────────────────────────────────────

model MedicalRecord {
  id        String   @id @default(uuid())
  patientId String
  doctorId  String
  notes     String
  createdAt DateTime @default(now())

  patient       PatientProfile @relation(fields: [patientId], references: [id], onDelete: Cascade)
  diagnoses     Diagnosis[]
  prescriptions Prescription[]

  @@index([patientId])
}

// ─────────────────────────────────────────────
// Diagnosis
// ─────────────────────────────────────────────

model Diagnosis {
  id          String   @id @default(uuid())
  recordId    String
  title       String
  description String
  createdAt   DateTime @default(now())

  record MedicalRecord @relation(fields: [recordId], references: [id], onDelete: Cascade)
}

// ─────────────────────────────────────────────
// Prescription
// ─────────────────────────────────────────────

model Prescription {
  id         String   @id @default(uuid())
  recordId   String
  medication String
  dosage     String
  createdAt  DateTime @default(now())

  record MedicalRecord @relation(fields: [recordId], references: [id], onDelete: Cascade)
}

// ─────────────────────────────────────────────
// Lab Result
// ─────────────────────────────────────────────

model LabResult {
  id        String   @id @default(uuid())
  patientId String
  fileUrl   String
  title     String
  createdAt DateTime @default(now())

  patient PatientProfile @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([patientId])
}
